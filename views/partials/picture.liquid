<picture class=" {{ class }} ">
  <source
    type="image/avif"
    srcset="{{  imgURL  }}?format=avif&q=80"
  >
  <source
    type="image/webp"
    srcset="{{   imgURL  }}?format=webp"
  >
  <img
    src=" {{imgURL  | append: width }}"
    alt="{{ imgALT }}"
    width="{{ width }}"
    height="{{ height }}"
    loading="{{ loading }}"
    fetchpriority="{{ priority }}"
  >

  {% comment %} {{ imgURL }} {% endcomment %}
</picture>
