<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styleguide.css">
    <link rel="stylesheet" href="/css/style.css">
    <title>{{ title }}</title>
  </head>
  <body>
    <header>
      <ul>
        <li> {% include "./partials/link.liquid", link: '#', text: "FAQ's", style: 'nav-link' %} </li>
        <li>{% include "./partials/link.liquid", link: '#', text: "Over ons", style: 'nav-link' %}</li>
        <li>{% include "./partials/link.liquid", link: '#', text: "Contact", style: 'nav-link' %}</li>
      </ul>
      <nav>
        <ul class="nav-list">
          <li>
            <img src="/img/logo-big.svg" alt="Overlegplatform ad">
          </li>
          <li>{% include "./partials/link.liquid", link: '#', text: "Home", style: 'nav-link' %}</li>
          <li>{% include "./partials/link.liquid", link: '#', text: "Over Ad's", style: 'nav-link' %}</li>
          <li>{% include "./partials/link.liquid", link: '#', text: "Publicaties", style: 'nav-link' %}</li>
          <li
            class="{% if  path  == '/talent-awards' %}
            active
          {% endif %}" 
          > 
          {% include "./partials/link.liquid", link: '/talent-awards', text: "Talent Award", style: 'nav-link' %}</li>
          <li>{% include "./partials/link.liquid", link: '#', text: "Nieuws", style: 'nav-link' %}</li>
          <li>{% include "./partials/link.liquid", link: '#', text: "kom naar Ad-dag ", style: 'primary-button' %}</li>
          <li><button>Hamburger</button></li>
        </ul>
      </nav>
    </header>
  {% comment %} </body>
</html> {% endcomment %}
